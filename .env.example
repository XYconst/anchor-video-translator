# ─────────────────────────────────────────────────────────────────────
# Required — both keys must be set for the pipeline to run.
# ─────────────────────────────────────────────────────────────────────

# ElevenLabs: voice cloning + TTS + vocal isolation.
# Get one at https://elevenlabs.io/app/settings/api-keys
# Paid plan recommended; voice cloning + dubbing burn through credits fast.
ELEVENLABS_API_KEY=

# KIE.ai: proxy for Gemini-3-Flash (transcription + translation + word
# timestamp alignment). Cheaper than calling Google Gemini directly.
# Get one at https://kie.ai (sign up, copy the API key from the dashboard).
KIE_API_KEY=

# ─────────────────────────────────────────────────────────────────────
# Optional — sensible defaults if you leave these blank.
# ─────────────────────────────────────────────────────────────────────

# Number of translations the backend will run in parallel inside one
# process. Default 3. Push to 5 if your machine has 16 GB+ RAM and 6+
# cores. Above 5, demucs (vocal isolation) starts fighting itself.
MAX_CONCURRENT_JOBS=3

# Where uploaded videos and rendered cuts live on disk. Default is
# ./uploads relative to backend/. Mount a persistent volume here in
# production so jobs survive container restarts.
UPLOAD_DIR=./uploads

# Frontend → backend wire. Override if the backend isn't on localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000
